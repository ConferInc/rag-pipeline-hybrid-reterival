# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<password>
NEO4J_DATABASE=neo4j

# OpenAI / LiteLLM
OPENAI_BASE_URL=https://your-litellm-proxy/v1
OPENAI_API_KEY=<key>
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Generation (optional; overrides embedding_config.yaml)
# GENERATION_MODEL=openai/gpt-4o-mini
# GENERATION_MAX_TOKENS=1024

# RAG API (for B2C frontend integration)
RAG_API_KEY=<shared-secret-with-express-backend>
ALLOWED_ORIGINS=http://localhost:5000
EMBEDDING_CONFIG=embedding_config.yaml
